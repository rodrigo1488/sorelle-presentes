# Copie para server/.env e ajuste os valores.
# Senhas com @ na DATABASE_URL devem usar URL-encoding (%40).

# --- Banco de dados (obrigatório) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sorelle

# --- Autenticação (obrigatório) ---
JWT_SECRET=GERE_UMA_CHAVE_LONGA_ALEATORIA
JWT_EXPIRES_IN=7d

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- URLs públicas (CORS e callbacks de pagamento) ---
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000

# --- Seed do admin (npm run db:seed) ---
ADMIN_EMAIL=admin@sorelle.com.br
ADMIN_PASSWORD=admin123

# --- Checkout / pagamento ---
# Opções: pix | cartao_credito | boleto | test (test = aprova sem cobrança real)
CHECKOUT_PAYMENT_METHOD=test
PIX_KEY=
PIX_HOLDER_NAME=Sorelle Presentes

# --- Cielo (cartão e boleto) ---
CIELO_MERCHANT_ID=
CIELO_SOFT_DESCRIPTOR=SORELLE
CIELO_MAX_INSTALLMENTS=12
CIELO_CHECKOUT_URL=https://cieloecommerce.cielo.com.br/api/public/v1/orders/

# --- Frete — Correios ---
CORREIOS_ORIGIN_ZIP=01310100
CORREIOS_COMPANY_CODE=
CORREIOS_PASSWORD=
# auto | estimate | off (em dev o padrão é auto se vazio)
CORREIOS_FALLBACK=auto
CORREIOS_DEFAULT_WEIGHT_KG=0.3
CORREIOS_DEFAULT_LENGTH_CM=20
CORREIOS_DEFAULT_WIDTH_CM=15
CORREIOS_DEFAULT_HEIGHT_CM=10

# --- Frete — transportadora fixa (alternativa aos Correios) ---
SHIPPING_CARRIER_ENABLED=false
SHIPPING_CARRIER_NAME=Transportadora
SHIPPING_CARRIER_PRICE=
SHIPPING_CARRIER_DEADLINE_DAYS=10

# --- Geração de imagens (opcional) ---
STABLE_HORDE_API_KEY=
