# Copie para .env ou .env.local na raiz do projeto (frontend Vite).

# URL base da API — ordem de prioridade em runtime (apiClient.js):
#   1. window.__SORELLE_API_URL__  (public/sorelle-config.js ou gerado no deploy)
#   2. VITE_API_URL                (esta variável, embutida no build)
#   3. /api                        (fallback — mesmo domínio com proxy Nginx/Vite)

# Desenvolvimento: /api usa o proxy do Vite → http://localhost:3001
VITE_API_URL=/api

# Desenvolvimento sem proxy (chamada direta ao backend):
# VITE_API_URL=http://localhost:3001/api

# Produção com API em subdomínio:
# VITE_API_URL=https://api.seudominio.com.br/api
