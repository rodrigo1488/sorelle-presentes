# Copie para .env.docker e ajuste antes de subir a stack:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up -d --build

POSTGRES_PASSWORD=ALTERE_SENHA_FORTE
JWT_SECRET=GERE_UMA_CHAVE_LONGA_ALEATORIA
JWT_EXPIRES_IN=7d

# Domínio público (DNS A → IP do servidor)
DOMAIN=sorellepresentes.com.br
SITE_HOST=www.sorellepresentes.com.br
API_HOST=api.sorellepresentes.com.br

# URLs usadas pelo backend (CORS, Cielo, etc.)
CORS_ORIGIN=https://www.sorellepresentes.com.br
FRONTEND_URL=https://www.sorellepresentes.com.br
APP_PUBLIC_URL=https://www.sorellepresentes.com.br

# URL da API no build React (/api = mesmo domínio via Nginx)
VITE_API_URL=/api

# Porta HTTP do gateway Nginx (80 em produção; use 8080 se aaPanel já ocupa a 80)
GATEWAY_HTTP_PORT=80

ADMIN_EMAIL=admin@sorelle.com.br
ADMIN_PASSWORD=ALTERE_SENHA_ADMIN
CHECKOUT_PAYMENT_METHOD=pix
